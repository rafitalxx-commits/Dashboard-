ODOO_URL=https://example.odoo.com
ODOO_DATABASE=database_name
ODOO_USERNAME=readonly@example.com
ODOO_API_KEY=replace-with-api-key
ODOO_WRITE_ENABLED=false
ODOO_WRITE_USERNAME=readonly-write-disabled@example.com
ODOO_WRITE_API_KEY=replace-only-when-approved
GOOGLE_CALENDAR_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=https://dashboard.todoelectrico.net/oauth2/callback
GOOGLE_CALENDAR_TIME_ZONE=Europe/Madrid
